# Copy to .env for local backend (do not commit secrets)

# Comma-separated browser origins allowed to call the API
# Example: https://arcus.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Your Vercel frontend URL (optional shortcut — also added to ALLOWED_ORIGINS)
FRONTEND_URL=https://arcus-malvikas-projects-c40a1b10.vercel.app

# Supabase — enable when migrating off local CSV files
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: copy from `select id from companies where name = 'Arcus'` after running schema.sql
ARCUS_COMPANY_ID=

# Receipt OCR
# Local: brew install tesseract tesseract-lang
# Optional override if tesseract is not on PATH:
# TESSDATA_PREFIX=
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
#
# Production (recommended): free OCR.space key → much faster + better than Tesseract on Render
# Get a key at https://ocr.space/ocrapi and set on Render:
# OCR_SPACE_API_KEY=your_key_here
#
# Ultra-fast degraded Tesseract (not recommended for receipts):
# ARCUS_FAST_OCR=1
